# Copie para .env: cp .env.example .env
# Todas as variáveis abaixo são obrigatórias — a app não usa fallbacks.
#
# Dev local (Python/uvicorn): use MYSQL_HOST=127.0.0.1
# Deploy VPS (Docker): use o nome do container MySQL compartilhado (ex.: mysql_shared)

DOMAIN=changetracker.seudominio.com.br
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

MYSQL_HOST=mysql_shared
MYSQL_PORT=3306
MYSQL_DATABASE=change_tracker
MYSQL_USER=change_user
MYSQL_PASSWORD=troque-por-senha-forte

JWT_SECRET=troque-esta-chave-por-uma-bem-grande-e-aleatoria
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

STORAGE_PATH=storage/evidence
EVIDENCE_MAX_BYTES=2097152
EVIDENCE_MAX_FILES=10

APP_NAME=Change Tracker
